#!/bin/sh
# SPDX-License-Identifier: GPL-3.0-or-later

# External read-only forensic observer for the EV charger service.

SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "$0")" >/dev/null 2>&1 && pwd)
REPO_DIR=$(realpath "$SCRIPT_DIR/../../..")
CONFIG_PATH="$REPO_DIR/deploy/venus/config.venus_evcharger.ini"
exec 2>&1

python3 "$(realpath "$REPO_DIR/venus_evcharger_observer.py")" "$CONFIG_PATH"
